          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('groups returns 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "const data = pm.response.json();",
                  "pm.test('groups expose max_daily_minutes', function () {",
                  "  pm.expect(data.every((item) => Object.prototype.hasOwnProperty.call(item, 'max_daily_minutes'))).to.be.true;",
                  "});",
                  "if (Array.isArray(data) && data.length > 0) {",
                  "  const preferred = data.find((item) => item.name === pm.environment.get('group_name')) || data[0];",
                  "  if (preferred && preferred.id) {",
                  "    pm.environment.set('group_id', String(preferred.id));",
                  "    pm.environment.set('group_name', preferred.name || '');",
                  "  }",
                  "}"
                ]
              }
            }
          ]
        },
