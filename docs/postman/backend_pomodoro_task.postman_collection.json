                  "if (data.schedule_id) pm.environment.set('schedule_id', String(data.schedule_id));",
                  "if (data.execution_id) pm.environment.set('execution_id', String(data.execution_id));",
                  "if (data.queue_item_id) pm.environment.set('queue_item_id', String(data.queue_item_id));"
