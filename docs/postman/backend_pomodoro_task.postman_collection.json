          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('next activity returns 200 or 404', function () {",
                  "  pm.expect([200, 404]).to.include(pm.response.code);",
                  "});",
                  "if (pm.response.code === 200) {",
                  "  const data = pm.response.json();",
                  "  pm.test('queue keeps additive group and source fields', function () {",
                  "    pm.expect(data).to.have.property('queue_group_id');",
                  "    pm.expect(data).to.have.property('queue_group_name');",
                  "    pm.expect(data).to.have.property('position');",
                  "    pm.expect(data).to.have.property('source_queue_id');",
                  "    pm.expect(data).to.have.property('group_max_daily_minutes');",
                  "    pm.expect(data).to.have.property('group_consumed_daily_minutes');",
                  "    pm.expect(data).to.have.property('group_remaining_daily_minutes');",
                  "  });",
                  "  if (data.queue_item_id) pm.environment.set('queue_item_id', String(data.queue_item_id));",
                  "  if (data.queue_id) pm.environment.set('queue_id', String(data.queue_id));",
                  "  if (data.id) pm.environment.set('activity_id', String(data.id));",
                  "  if (data.name) pm.environment.set('activity_name', data.name);",
                  "  if (data.category) pm.environment.set('category_id', String(data.category));",
                  "} else {",
                  "  const data = pm.response.json();",
                  "  pm.test('empty queue has structured reason and context', function () {",
                  "    pm.expect(data.code).to.eql('no_activity_available');",
                  "    pm.expect(data).to.have.property('reason');",
                  "    pm.expect(data).to.have.property('queue_group_id');",
                  "    pm.expect(data).to.have.property('group_remaining_daily_minutes');",
                  "  });",
                  "}"
                ]
              }
            }
          ]
