# Django
APP_ENV=production
DJANGO_SECRET_KEY=gere_uma_chave_forte
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=seu_dominio_ou_ip
DJANGO_CSRF_TRUSTED_ORIGINS=http://seu_dominio_ou_ip
DJANGO_STATIC_ROOT=/app/staticfiles
DJANGO_MEDIA_ROOT=/app/media

# PostgreSQL central da VPS
DB_HOST=postgres
DB_PORT=5432
DB_NAME=pomodoro_task_prod
DB_USER=pomodoro_task_user
DB_PASS=gere_uma_senha_forte

# Inicialização e Gunicorn
WAIT_FOR_DATABASE=true
WAIT_FOR_DATABASE_SECONDS=60
GUNICORN_WORKERS=2
GUNICORN_THREADS=2
GUNICORN_TIMEOUT=60

# Nginx do container, acessível somente pelo host
NGINX_BIND=127.0.0.1
NGINX_PORT=8080
